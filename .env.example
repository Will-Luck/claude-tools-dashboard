# claude-tools-dashboard configuration
# All values shown are defaults -- only set what you need to override.

# Dashboard listen port
PORT=8095

# Bind address. 0.0.0.0 listens on all interfaces; set 127.0.0.1 to expose the
# dashboard only behind a reverse proxy.
HOST=0.0.0.0

# Headroom proxy URL (stats and health endpoints)
HEADROOM_URL=http://127.0.0.1:8787

# RTK SQLite database path
RTK_DB_PATH=~/.local/share/rtk/history.db

# RTK binary name or path (uses PATH by default)
RTK_BIN=rtk

# jCodeMunch index directory (contains _savings.json and .db files)
JCODEMUNCH_INDEX_DIR=~/.code-index

# jCodeMunch binary name or path (used for version check)
JCODEMUNCH_BIN=jcodemunch-mcp

# jDocMunch index directory
JDOCMUNCH_INDEX_DIR=~/.doc-index

# jDocMunch binary name or path (used for version check)
JDOCMUNCH_BIN=jdocmunch-mcp

# jDataMunch index directory
JDATAMUNCH_INDEX_DIR=~/.data-index

# jDataMunch binary name or path (used for version check)
JDATAMUNCH_BIN=jdatamunch-mcp

# SSE heartbeat push interval in seconds
SSE_INTERVAL=2

# Background collector tick interval in seconds
COLLECTOR_INTERVAL=0.25

# Claude Code credentials file (for usage API)
CLAUDE_CREDENTIALS=~/.claude/.credentials.json

# Directory for weekly savings snapshots
WEEKLY_CACHE_DIR=~/.cache/claude-tools-dashboard
